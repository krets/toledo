def cmd_config(args):
    config = load_config()
    if not args.key:
        print(json.dumps(config, indent=2))
        return

    parts = args.key.split(".")
    
    if args.value is None and not args.unset:
        # Get
        val = config
        for p in parts:
            if isinstance(val, dict) and p in val:
                val = val[p]
            else:
                val = None; break
        if val is not None:
            print(val if not isinstance(val, (dict, list)) else json.dumps(val))
        return

    if args.unset:
        # Unset
        val = config
        for p in parts[:-1]:
            if p in val and isinstance(val[p], dict):
                val = val[p]
            else:
                return
        if parts[-1] in val:
            del val[parts[-1]]
            save_config(config)
            print(f"✓ Unset {args.key}")
        return

    # Set
    val = config
    for p in parts[:-1]:
        if p not in val or not isinstance(val[p], dict):
            val[p] = {}
        val = val[p]
    
    new_val = args.value
    # Try to parse as JSON for bools/ints/etc, fallback to string
    try:
        new_val = json.loads(args.value)
    except:
        pass
        
    val[parts[-1]] = new_val
    save_config(config)
    print(f"✓ {args.key} = {new_val}")


def cmd_log(args):
    ctx = getattr(args, "task", None) or get_context()
    if not ctx: print("✗ No task/context."); return
    r = find_task(ctx)
    if not r: print(f"✗ Task '{ctx}' not found."); return
    task_folder, _ = r
    lf = task_folder / "activity.log"
    if not lf.exists(): print("No activity log."); return
    print(f"Log for '{task_folder.name}':\n")
    for line in lf.read_text().splitlines():
        e = json.loads(line)
        ts, action = e.pop("ts"), e.pop("action")
        extras = "  ".join(f"{k}={v}" for k, v in e.items())
        print(f"  {ts}  {action:<28} {extras}")


def serialize_task_folder(task_folder):
    """Recursively turn a task folder into a dict."""
    task_data = {
        "slug": task_folder.name,
        "files": {},
        "dirs": {}
    }
    for item in task_folder.iterdir():
        if item.is_file():
            task_data["files"][item.name] = item.read_text()
        elif item.is_dir():
            if item.name == "subtasks":
                task_data["subtasks"] = {}
                for sstate in SUBTASK_STATES:
                    sstate_dir = item / sstate
                    if sstate_dir.exists():
                        task_data["subtasks"][sstate] = [
                            serialize_task_folder(sub) for sub in sstate_dir.iterdir() if sub.is_dir()
                        ]
            else:
                task_data["dirs"][item.name] = {
                    f.name: f.read_text() for f in item.iterdir() if f.is_file()
                }
    return task_data


def restore_task_folder(parent_dir, task_data):
    """Recursively restore a task folder from a dict."""
    task_folder = parent_dir / task_data["slug"]
    ensure_dir(task_folder)
    for fname, content in task_data.get("files", {}).items():
        (task_folder / fname).write_text(content)

    for dirname, dir_content in task_data.get("dirs", {}).items():
        dpath = task_folder / dirname
        ensure_dir(dpath)
        for fname, fcontent in dir_content.items():
            (dpath / fname).write_text(fcontent)

    if "subtasks" in task_data:
        for state, subtasks in task_data["subtasks"].items():
            for sub_data in subtasks:
                restore_task_folder(task_folder / "subtasks" / state, sub_data)


def cmd_export(args):
    data = {
        "version": "1.0",
        "exported_at": datetime.now().isoformat(),
        "projects": load_projects(),
        "context": get_context(),
        "tasks": {}
    }
    tasks_dir = get_tasks_dir()
    for state in STATES:
        sd = tasks_dir / state
        if not sd.exists(): continue
        data["tasks"][state] = [
            serialize_task_folder(t) for t in sd.iterdir() if t.is_dir()
        ]
    Path(args.file).write_text(json.dumps(data, indent=2))
    print(f"✓ Exported everything to {args.file}")


def cmd_import(args):
    fpath = Path(args.file)
    if not fpath.exists():
        print(f"✗ File '{args.file}' not found."); return
    data = json.loads(fpath.read_text())

    tasks_dir = get_tasks_dir()
    init_tasks_dir()

    if "projects" in data:
        projects = load_projects()
        projects.update(data["projects"])
        save_projects(projects)

    for state, tasks in data.get("tasks", {}).items():
        for task_data in tasks:
            restore_task_folder(tasks_dir / state, task_data)

    if "context" in data and data["context"]:
        set_context(data["context"])

    print(f"✓ Imported everything from {args.file}")


