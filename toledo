def cmd_edit(args):
    ctx = getattr(args, "task", None) or get_context()
    if not ctx: print("✗ No task/context."); return
    r = find_task(ctx)
    if not r: print(f"✗ Task '{ctx}' not found."); return
    task_folder, _ = r
    df = task_folder / "description.md"
    if df.exists():
        ad = task_folder / "description_archive"
        ensure_dir(ad)
        df.rename(ad / f"description_{datetime.now().strftime('%Y%m%d_%H%M%S')}.md")
    df.write_text(args.text)
    append_log(task_folder, "description_updated")
    print(f"✓ Description updated (old version archived)")


def cmd_due(args):
    ctx = getattr(args, "task", None) or get_context()
    if not ctx: print("✗ No task/context."); return
    r = find_task(ctx)
    if not r: print(f"✗ Task '{ctx}' not found."); return
    task_folder, _ = r
    (task_folder / "due.txt").write_text(args.date)
    append_log(task_folder, "due_date_set", date=args.date)
    print(f"✓ Due date → {args.date}")


def cmd_proj(args):
    projects = load_projects()
    if getattr(args, "remove", None):
        code = args.remove.upper()
        if code not in projects:
            print(f"✗ Project '{code}' not found."); return
        del projects[code]
        save_projects(projects)
        print(f"✓ Removed project '{code}'")
        return
    if getattr(args, "list", False) or not (getattr(args, "code", None) and getattr(args, "name", None)):
        if not projects:
            print("No projects defined.")
        else:
            print(f"  {'CODE':<8}  {'NAME':<30}  COLOR")
            print(f"  {'-'*8}  {'-'*30}  -----")
            for code, val in sorted(projects.items()):
                if isinstance(val, dict):
                    name  = val.get("name", "")
                    color = val.get("color") or "(none)"
                else:
                    name, color = str(val), "(none)"
                print(f"  {code:<8}  {name:<30}  {color}")
        return
    code = args.code.upper()
    color = getattr(args, "color", None)
    existing = projects.get(code)
    if isinstance(existing, dict):
        existing["name"] = args.name
        if color:
            existing["color"] = color
        projects[code] = existing
    else:
        projects[code] = {"name": args.name, "color": color or ""}
    save_projects(projects)
    color_str = f"  color={color}" if color else ""
    print(f"✓ Project '{code}' = '{args.name}'{color_str}")


def cmd_show(args):
    ctx = getattr(args, "task", None) or get_context()
    if not ctx: print("✗ No task/context."); return
    r = find_task(ctx)
    if not r: print(f"✗ Task '{ctx}' not found."); return
    task_folder, _ = r
    df = task_folder / "description.md"
    if not df.exists(): print("No description."); return
    print(df.read_text())


def cmd_search(args):
    query = args.query.lower()
    found = False
    for state in STATES:
        sd = get_tasks_dir() / state
        if not sd.exists(): continue
        for task in sorted(sd.iterdir()):
            if not task.is_dir(): continue
            hits = []
            if query in task.name.lower():
                hits.append("name")
            for fname in ("description.md", "worklog.md"):
                f = task / fname
                if f.exists() and query in f.read_text().lower():
                    hits.append(fname)
            if hits:
                found = True
                info = parse_task_slug(task.name)
                df = task / "due.txt"
                due_s = f" · due {df.read_text().strip()}" if df.exists() else ""
                print(f"[{state}] **[{info['priority']:02d}]** `{info['project']}` "
                      f"{info['name'].title()}{due_s}  ({', '.join(hits)})")
    if not found:
        print(f"No tasks matching '{args.query}'.")


def cmd_subdone(args):
    ctx = get_context()
    if not ctx: print("✗ No context. Use 'ctx <task>' first."); return
    r = find_task(ctx)
    if not r: print(f"✗ Context task '{ctx}' not found."); return
    task_folder, _ = r
    active_dir = task_folder / "subtasks" / "active"
    if not active_dir.exists(): print("No active subtasks."); return
    matches = [f for f in active_dir.iterdir()
               if f.is_dir() and args.name.lower() in f.name.lower()]
    if not matches:
        print(f"✗ No active subtask matching '{args.name}'."); return
    if len(matches) > 1:
        print(f"✗ Ambiguous — matches: {', '.join(f.name for f in matches)}"); return
    sub = matches[0]
    done_dir = task_folder / "subtasks" / "completed"
    ensure_dir(done_dir)
    sub.rename(done_dir / sub.name)
    append_log(task_folder, "subtask_completed", subtask=sub.name)
    print(f"✓ Subtask '{sub.name}' marked complete")


def cmd_upcoming(args):
    days = getattr(args, "days", 7)
    today = datetime.now().date()
    cutoff = (today + timedelta(days=days)).strftime("%Y-%m-%d")
    today_s = today.strftime("%Y-%m-%d")
    found = False
    for state in ["active"]:
        sd = get_tasks_dir() / state
        if not sd.exists(): continue
        tasks = [f for f in sd.iterdir() if f.is_dir()]
        tasks = [t for t in tasks if (t / "due.txt").exists()]
        tasks = [t for t in tasks if (t / "due.txt").read_text().strip() <= cutoff]
        tasks.sort(key=lambda t: (t / "due.txt").read_text().strip())
        for task in tasks:
            found = True
            info = parse_task_slug(task.name)
            due = (task / "due.txt").read_text().strip()
            overdue = due < today_s
            tag = " ⚠ OVERDUE" if overdue else (" · today" if due == today_s else f" · due {due}")
            print(f"[{state}] **[{info['priority']:02d}]** `{info['project']}` "
                  f"{info['name'].title()}{tag}")
    if not found:
        print(f"No tasks due within {days} day(s).")


def cmd_archive(args):
    r = find_task(args.task)
    if not r: print(f"✗ Task '{args.task}' not found."); return
    task_folder, cur = r
    if cur == "archive":
        print("Already archived."); return
    nf = get_tasks_dir() / "archive" / task_folder.name
    task_folder.rename(nf)
    append_log(nf, "state_changed", from_state=cur, to_state="archive")
    print(f"✓ Archived '{task_folder.name}'")


def cmd_rm(args):
    r = find_task(args.task)
    if not r: print(f"✗ Task '{args.task}' not found."); return
    task_folder, state = r
    answer = input(f"Delete '{task_folder.name}' ({state}) permanently? [y/N] ")
    if answer.strip().lower() != "y":
        print("Aborted."); return
    import shutil
    shutil.rmtree(task_folder)
    print(f"✓ Deleted '{task_folder.name}'")


def cmd_reprioritize(args):
    r = find_task(args.task)
    if not r: print(f"✗ Task '{args.task}' not found."); return
    task_folder, state = r
    old_info = parse_task_slug(task_folder.name)
    old_pri  = old_info["priority"]
    new_pri  = args.priority
    if old_pri == new_pri:
        print(f"✗ Task already has priority {new_pri}."); return
    new_slug   = f"{new_pri:02d}-{old_info['project']}-{old_info['name'].replace(' ', '-')}"
    new_folder = get_tasks_dir() / state / new_slug
    if new_folder.exists():
        print(f"✗ A task with slug '{new_slug}' already exists."); return
    task_folder.rename(new_folder)
    # Update context if it pointed to the old slug
    if get_context() == task_folder.name:
        set_context(new_slug)
    append_log(new_folder, "reprioritized", old_priority=old_pri, new_priority=new_pri)
    print(f"✓ '{task_folder.name}' → '{new_slug}'")


