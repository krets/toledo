#!/usr/bin/env python3
"""
Toledo - A file-based task manager CLI

Config:  ~/.toledo.json              (tasks_dir key)
Tasks:   ~/.toledo/tasks/            (default)
Context: ~/.toledo/.context

Usage examples:
    toledo init
    toledo new "Fix login bug" -p 10 -c WEB --due 2026-04-15
    toledo new "Weekly review" -p 20 -c GEN --recur 7
    toledo status
    toledo ctx fix-login
    toledo sub "Write unit tests" -p 20
    toledo note "Found the issue in auth.py line 42"
    toledo done fix-login
    toledo cancel weekly-review
    toledo log
    toledo proj                    (list)
    toledo proj WEB "Web Frontend"  (add)
    toledo proj -r WEB              (remove)
"""

import argparse
import json
import re
from datetime import datetime, timedelta
from pathlib import Path

CONFIG_PATH = Path.home() / ".toledo.json"
DEFAULT_TASKS_DIR = Path.home() / ".toledo" / "tasks"
CONTEXT_FILE = Path.home() / ".toledo" / ".context"

STATES = ["active", "completed", "archive"]
SUBTASK_STATES = ["active", "completed"]


# ── Config & helpers ──────────────────────────────────────────────────────────

def load_config():
    if CONFIG_PATH.exists():
        with open(CONFIG_PATH) as f:
            return json.load(f)
    return {"tasks_dir": str(DEFAULT_TASKS_DIR)}

def save_config(config):
    CONFIG_PATH.write_text(json.dumps(config, indent=2))

def get_tasks_dir():
    return Path(load_config().get("tasks_dir", DEFAULT_TASKS_DIR))

def ensure_dir(path):
    path.mkdir(parents=True, exist_ok=True)

def init_tasks_dir():
    for state in STATES:
        ensure_dir(get_tasks_dir() / state)
    ensure_dir(Path.home() / ".toledo")

def load_projects():
    pf = get_tasks_dir() / "projects.json"
    if not pf.exists():
        return {}
    data = json.loads(pf.read_text())
    # Migrate old string format {"CODE": "name"} to {"CODE": {"name": ..., "color": ...}}
    migrated = False
    for code, val in list(data.items()):
        if isinstance(val, str):
            data[code] = {"name": val, "color": ""}
            migrated = True
    if migrated:
        save_projects(data)
    return data

class Spinner:
    def __init__(self, message="Thinking..."):
        self.message = message
        self.stop_running = False
        self.thread = None

    def _spin(self):
        import time
        import sys
        chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        i = 0
        while not self.stop_running:
            sys.stdout.write(f"\r {chars[i]} {self.message}")
            sys.stdout.flush()
            i = (i + 1) % len(chars)
            time.sleep(0.1)
        sys.stdout.write("\r" + " " * (len(self.message) + 10) + "\r")
        sys.stdout.flush()

    def __enter__(self):
        import threading
        self.stop_running = False
        self.thread = threading.Thread(target=self._spin)
        self.thread.start()
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        self.stop_running = True
        if self.thread:
            self.thread.join()

def save_projects(p):
    pf = get_tasks_dir() / "projects.json"
    pf.write_text(json.dumps(p, indent=2))

def proj_display_name(projects, code):
    """Return the display name for a project code."""
    val = projects.get(code)
    if isinstance(val, dict):
        return val.get("name", code)
    return str(val) if val else code

def make_task_slug(priority, project_code, name):
    slug = re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")
    return f"{priority:02d}-{project_code.upper()}-{slug}"

def parse_task_slug(slug):
    parts = slug.split("-", 2)
    if len(parts) < 3:
        return {"priority": 0, "project": "??", "name": slug}
    return {
        "priority": int(parts[0]) if parts[0].isdigit() else 0,
        "project": parts[1],
        "name": parts[2].replace("-", " "),
    }

def find_task(partial):
    for state in STATES:
        sd = get_tasks_dir() / state
        if not sd.exists():
            continue
        for folder in sd.iterdir():
            if folder.is_dir() and partial.lower() in folder.name.lower():
                return folder, state
    return None

def append_log(task_folder, action, **kwargs):
    entry = {"ts": datetime.now().isoformat(), "action": action, **kwargs}
    with open(task_folder / "activity.log", "a") as f:
        f.write(json.dumps(entry) + "\n")

def get_context():
    return CONTEXT_FILE.read_text().strip() if CONTEXT_FILE.exists() else None

def set_context(slug):
    ensure_dir(CONTEXT_FILE.parent)
    CONTEXT_FILE.write_text(slug)

def clear_context():
    if CONTEXT_FILE.exists():
        CONTEXT_FILE.unlink()


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_chat(args):
    import requests
    import os

    config = load_config()
    server_port = 8000 # Default

    messages = []
    
    if args.message:
        messages.append({"role": "user", "content": " ".join(args.message)})
        try:
            with Spinner():
                r = requests.post(f"http://localhost:{server_port}/api/chat", json={"messages": messages})
                r.raise_for_status()
                res = r.json()
            print(f"\n{res.get('message')}\n")
        except Exception as e:
            print(f"✗ Error: {e} (Is the server running?)")
        return

    print(f"Chatting with Toledo (via server). Type 'exit' to quit.\n")
    while True:
        try:
            user_input = input("user> ")
            if user_input.lower() in ("exit", "quit"): break
            if not user_input.strip(): continue
            
            messages.append({"role": "user", "content": user_input})
            
            with Spinner():
                r = requests.post(f"http://localhost:{server_port}/api/chat", json={"messages": messages})
                r.raise_for_status()
                res = r.json()
            
            # Update history from server (compacted if needed)
            messages = res.get("history", messages)
            
            print(f"ai> {res.get('message')}\n")

        except KeyboardInterrupt:
            print("\nInterrupted."); break
        except Exception as e:
            print(f"\n✗ Error: {e} (Is the server running?)")


def cmd_init(args):
    init_tasks_dir()
    if not CONFIG_PATH.exists():
        CONFIG_PATH.write_text(json.dumps({"tasks_dir": str(DEFAULT_TASKS_DIR)}, indent=2))
    print(f"✓ Toledo initialized at {get_tasks_dir()}")


def cmd_new(args):
    init_tasks_dir()
    priority = args.priority or 50
    project = (args.project or "GEN").upper()
    slug = make_task_slug(priority, project, args.name)
    state = "active"
    task_folder = get_tasks_dir() / state / slug

    if task_folder.exists():
        print(f"✗ Task '{slug}' already exists in {state}/"); return

    ensure_dir(task_folder)
    desc = args.description or f"# {args.name}\n\n_No description provided._\n"
    if not desc.startswith("#"):
        desc = f"# {args.name}\n\n{desc}\n"
    (task_folder / "description.md").write_text(desc)
    if args.due:
        (task_folder / "due.txt").write_text(args.due)
    if args.recur:
        (task_folder / "recurrence.txt").write_text(str(args.recur))
    append_log(task_folder, "created", state=state, priority=priority, project=project)
    print(f"✓ Created '{slug}' in {state}/")
    if args.recur:
        print(f"  Recurs every {args.recur} day(s)")


def is_overdue(task_folder):
    df = task_folder / "due.txt"
    if not df.exists(): return False
    try:
        return df.read_text().strip() < datetime.now().strftime("%Y-%m-%d")
    except Exception:
        return False


def cmd_status(args):
    projects = load_projects()
    project_filter = getattr(args, "project", None)
    if project_filter:
        project_filter = project_filter.upper()
    lines = ["# Toledo Task Status\n",
             f"_Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}_\n"]
    if project_filter:
        label = proj_display_name(projects, project_filter)
        lines.append(f"_Project filter: `{project_filter}` — {label}_\n")
    show = STATES if getattr(args, "all", False) else ["active", "completed"]

    for state in show:
        sd = get_tasks_dir() / state
        if not sd.exists(): continue
        tasks = [f for f in sd.iterdir() if f.is_dir()]
        if project_filter:
            tasks = [t for t in tasks if parse_task_slug(t.name)["project"] == project_filter]
        if not tasks: continue

        def sort_key(t):
            info = parse_task_slug(t.name)
            df = t / "due.txt"
            return (info["priority"], df.read_text().strip() if df.exists() else "9999")

        tasks.sort(key=sort_key)
        lines.append(f"\n## {state.capitalize()}\n")

        for task in tasks:
            info = parse_task_slug(task.name)
            df = task / "due.txt"
            rf = task / "recurrence.txt"
            due_str = df.read_text().strip() if df.exists() else None
            overdue = due_str and due_str < datetime.now().strftime("%Y-%m-%d")
            due_s = f" · due {due_str}" if due_str else ""
            if overdue: due_s += " ⚠ OVERDUE"
            rec_s = f" · every {rf.read_text().strip()}d" if rf.exists() else ""
            lines.append(f"- **[{info['priority']:02d}]** `{info['project']}` "
                         f"{info['name'].title()}{due_s}{rec_s}")
            for ss in SUBTASK_STATES:
                sub_dir = task / "subtasks" / ss
                if sub_dir.exists():
                    for sub in sorted(sub_dir.iterdir()):
                        if sub.is_dir():
                            si = parse_task_slug(sub.name)
                            check = "x" if ss == "completed" else " "
                            lines.append(f"  - [{check}] {si['name'].title()}")

    print("\n".join(lines))


def cmd_move(args):
    r = find_task(args.task)
    if not r: print(f"✗ Task '{args.task}' not found."); return
    task_folder, cur = r
    new_folder = get_tasks_dir() / args.to / task_folder.name
    task_folder.rename(new_folder)
    append_log(new_folder, "state_changed", from_state=cur, to_state=args.to)
    print(f"✓ Moved '{task_folder.name}': {cur} → {args.to}")


def cmd_done(args):
    r = find_task(args.task)
    if not r: print(f"✗ Task '{args.task}' not found."); return
    task_folder, cur = r
    rf = task_folder / "recurrence.txt"
    if rf.exists():
        days = int(rf.read_text().strip())
        new_due = (datetime.now() + timedelta(days=days)).strftime("%Y-%m-%d")
        (task_folder / "due.txt").write_text(new_due)
        append_log(task_folder, "completed_recurring", next_due=new_due)
        print(f"✓ Done. Next due: {new_due}")
    else:
        nf = get_tasks_dir() / "completed" / task_folder.name
        task_folder.rename(nf)
        append_log(nf, "state_changed", from_state=cur, to_state="completed")
        print(f"✓ Completed '{task_folder.name}'")


def cmd_cancel(args):
    r = find_task(args.task)
    if not r: print(f"✗ Task '{args.task}' not found."); return
    task_folder, cur = r
    if not (task_folder / "recurrence.txt").exists():
        print(f"✗ '{task_folder.name}' is not a recurring task. Use 'move' instead."); return
    nf = get_tasks_dir() / "completed" / task_folder.name
    task_folder.rename(nf)
    append_log(nf, "recurring_cancelled")
    print(f"✓ Cancelled recurring task → completed/")


def cmd_ctx(args):
    task_arg = getattr(args, "task", "show") or "show"
    if task_arg == "clear":
        clear_context(); print("✓ Context cleared."); return
    if task_arg == "show":
        ctx = get_context()
        print(f"Context: {ctx}" if ctx else "No context set."); return
    r = find_task(task_arg)
    if not r: print(f"✗ Task '{task_arg}' not found."); return
    task_folder, state = r
    set_context(task_folder.name)
    print(f"✓ Context → '{task_folder.name}' ({state})")


def cmd_sub(args):
    ctx = get_context()
    if not ctx: print("✗ No context. Use 'ctx <task>' first."); return
    r = find_task(ctx)
    if not r: print(f"✗ Context task '{ctx}' not found."); return
    task_folder, _ = r
    p = args.priority or 50
    slug = f"{p:02d}-{re.sub(r'[^a-z0-9]+', '-', args.name.lower()).strip('-')}"
    sf = task_folder / "subtasks" / "active" / slug
    ensure_dir(sf)
    (sf / "description.md").write_text(args.description or f"# {args.name}\n\n_No description._\n")
    if args.due:
        (sf / "due.txt").write_text(args.due)
    append_log(task_folder, "subtask_created", subtask=slug)
    print(f"✓ Added subtask '{slug}'")


def cmd_note(args):
